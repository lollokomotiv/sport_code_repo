# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=totosport

# URL per SQLAlchemy async (usato dal backend)
# In locale con postgres su Docker: usa localhost
# Nel container backend: usa il nome del servizio "db"
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/totosport

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-questa-stringa-con-una-sicura-di-64-caratteri
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── API-Football (RapidAPI) ──────────────────────────────────────────────────
# Registrati su https://rapidapi.com/api-sports/api/api-football
# Lascia vuoto per ora, serve solo dalla Fase 7
API_FOOTBALL_KEY=
API_FOOTBALL_HOST=v3.football.api-sports.io

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origini permesse per il frontend (separati da virgola se multipli)
ALLOWED_ORIGINS=["http://localhost:5173"]

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
